# Default desktop Google OAuth client for the Money Manager JVM build.
#
# Copy this file to `secrets/google-oauth.properties` (same directory) and fill in the values from a
# "Desktop app" OAuth client created in your Google Cloud project. The real file is .gitignored.
#
# These values are baked into the JVM build by the `generateGoogleOAuthDefaults` Gradle task (in
# app/remotestorage/googledrive/build.gradle.kts), XOR-obfuscated so the literal secret never appears
# in the artifact. In CI they come from the GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET
# secrets instead of this file. Builds without either source still compile — Google Drive just reports
# "not configured". Resolution order: env vars -> -Pgoogle.oauth.clientId / -Pgoogle.oauth.clientSecret
# -> this file.
#
# NOTE: Google classifies an installed-app client secret as non-confidential, but it still gates this
# project's quota — protect the Cloud project with a quota cap + budget alert and rotate the client id
# if it is abused.

clientId=YOUR_CLIENT_ID.apps.googleusercontent.com
clientSecret=YOUR_CLIENT_SECRET
