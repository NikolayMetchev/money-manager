{
    "version": "",
    "name": "Wise CSV",
    "identificationColumns": [
        "ID",
        "Status",
        "Direction",
        "Created on",
        "Finished on",
        "Source fee amount",
        "Source fee currency",
        "Target fee amount",
        "Target fee currency",
        "Source name",
        "Source amount (after fees)",
        "Source currency",
        "Target name",
        "Target amount (after fees)",
        "Target currency",
        "Exchange rate",
        "Reference",
        "Batch",
        "Created by",
        "Category",
        "Note"
    ],
    "fieldMappings": {
        "SOURCE_ACCOUNT": {
            "type": "com.moneymanager.domain.model.csvstrategy.export.TemplateAccountExport",
            "fieldType": "SOURCE_ACCOUNT",
            "columnName": "Source currency",
            "prefix": "Wise: ",
            "suffix": "",
            "defaultCategoryName": "Uncategorized"
        },
        "TARGET_ACCOUNT": {
            "type": "com.moneymanager.domain.model.csvstrategy.export.ConditionalAccountExport",
            "fieldType": "TARGET_ACCOUNT",
            "conditions": [
                {
                    "columnName": "Source name",
                    "operator": "EQUALS_COLUMN",
                    "value": null,
                    "otherColumnName": "Target name"
                },
                {
                    "columnName": "Source name",
                    "operator": "IS_NOT_BLANK",
                    "value": null,
                    "otherColumnName": null
                },
                {
                    "columnName": "Source currency",
                    "operator": "NOT_EQUALS_COLUMN",
                    "value": null,
                    "otherColumnName": "Target currency"
                }
            ],
            "whenTrue": {
                "type": "com.moneymanager.domain.model.csvstrategy.export.TemplateAccountExport",
                "fieldType": "TARGET_ACCOUNT",
                "columnName": "Target currency",
                "prefix": "Wise: ",
                "suffix": "",
                "defaultCategoryName": "Uncategorized"
            },
            "whenFalse": {
                "type": "com.moneymanager.domain.model.csvstrategy.export.AccountLookupExport",
                "fieldType": "TARGET_ACCOUNT",
                "columnName": "Target name",
                "fallbackColumns": [
                    "Source name"
                ],
                "defaultCategoryName": "Uncategorized"
            }
        },
        "TIMESTAMP": {
            "type": "com.moneymanager.domain.model.csvstrategy.export.DateTimeParsingExport",
            "fieldType": "TIMESTAMP",
            "dateColumnName": "Created on",
            "dateFormat": "yyyy-MM-dd",
            "timeColumnName": null,
            "timeFormat": null,
            "defaultTime": "12:00:00",
            "dateTimeFormat": "yyyy-MM-dd HH:mm:ss"
        },
        "DESCRIPTION": {
            "type": "com.moneymanager.domain.model.csvstrategy.export.DirectColumnExport",
            "fieldType": "DESCRIPTION",
            "columnName": "Reference",
            "fallbackColumns": [
                "Note",
                "Category",
                "Target name"
            ],
            "extraction": null
        },
        "AMOUNT": {
            "type": "com.moneymanager.domain.model.csvstrategy.export.AmountParsingExport",
            "fieldType": "AMOUNT",
            "mode": "SINGLE_COLUMN",
            "amountColumnName": "Source amount (after fees)",
            "creditColumnName": null,
            "debitColumnName": null,
            "negateValues": false,
            "flipAccountsOnPositive": false,
            "feeColumnName": "Source fee amount",
            "feeConditions": [
                {
                    "columnName": "Direction",
                    "operator": "EQUALS_VALUE",
                    "value": "OUT",
                    "otherColumnName": null
                }
            ]
        },
        "CURRENCY": {
            "type": "com.moneymanager.domain.model.csvstrategy.export.CurrencyLookupExport",
            "fieldType": "CURRENCY",
            "columnName": "Source currency"
        },
        "TIMEZONE": {
            "type": "com.moneymanager.domain.model.csvstrategy.export.HardCodedTimezoneExport",
            "fieldType": "TIMEZONE",
            "timezoneId": "UTC"
        }
    },
    "attributeMappings": [
        {
            "columnName": "ID",
            "attributeTypeName": "wise-id",
            "isUniqueIdentifier": true,
            "extraction": null,
            "emitWhenMatched": null
        },
        {
            "columnName": "Status",
            "attributeTypeName": "wise-status",
            "isUniqueIdentifier": false,
            "extraction": null,
            "emitWhenMatched": null
        },
        {
            "columnName": "Direction",
            "attributeTypeName": "wise-direction",
            "isUniqueIdentifier": false,
            "extraction": null,
            "emitWhenMatched": null
        },
        {
            "columnName": "Exchange rate",
            "attributeTypeName": "wise-exchange-rate",
            "isUniqueIdentifier": false,
            "extraction": null,
            "emitWhenMatched": null
        },
        {
            "columnName": "Category",
            "attributeTypeName": "wise-category",
            "isUniqueIdentifier": false,
            "extraction": null,
            "emitWhenMatched": null
        },
        {
            "columnName": "Note",
            "attributeTypeName": "note",
            "isUniqueIdentifier": false,
            "extraction": null,
            "emitWhenMatched": null
        },
        {
            "columnName": "Created by",
            "attributeTypeName": "wise-created-by",
            "isUniqueIdentifier": false,
            "extraction": null,
            "emitWhenMatched": null
        }
    ],
    "rowPreprocessingRules": [
        {
            "conditions": [
                {
                    "columnName": "Direction",
                    "operator": "EQUALS_VALUE",
                    "value": "IN",
                    "otherColumnName": null
                }
            ],
            "columnSwaps": [
                {
                    "firstColumn": "Source name",
                    "secondColumn": "Target name"
                },
                {
                    "firstColumn": "Source amount (after fees)",
                    "secondColumn": "Target amount (after fees)"
                },
                {
                    "firstColumn": "Source currency",
                    "secondColumn": "Target currency"
                }
            ],
            "flipSourceAndTarget": true
        }
    ],
    "companionTransactionRules": [
        {
            "name": "Interest earned",
            "matchAttributeName": "wise-id",
            "matchValuePattern": "ACCRUAL_CHARGE-%",
            "linkAttributeName": "wise-interest-for",
            "companionDescription": "Interest earned"
        }
    ],
    "contentMatchRules": [],
    "accountMappings": []
}