        CAST(strftime('%s', 'now') AS INTEGER) * 1000, 3, old.transaction_id,
        COALESCE((SELECT revision_id FROM transfer WHERE id = old.transaction_id), old.revision_id),
        old.attribute_type_id, old.attribute_value, old.group_key);
