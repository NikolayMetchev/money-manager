    FOREIGN KEY (audit_type_id) REFERENCES audit_type(id),
    FOREIGN KEY (attribute_type_id) REFERENCES attribute_type(id) ON DELETE RESTRICT
);

CREATE INDEX IF NOT EXISTS idx_person_attribute_audit_person_id ON person_attribute_audit(person_id);
CREATE INDEX IF NOT EXISTS idx_person_attribute_audit_revision ON person_attribute_audit(person_id, revision_id);

-- person_audit: Audit trail for person table
CREATE TABLE person_audit (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    audit_timestamp INTEGER NOT NULL,
    audit_type_id INTEGER NOT NULL,
    person_id INTEGER NOT NULL,
    revision_id INTEGER NOT NULL,
    first_name TEXT NOT NULL,
    middle_name TEXT,
    last_name TEXT,
    FOREIGN KEY (audit_type_id) REFERENCES audit_type(id)
);

CREATE INDEX IF NOT EXISTS idx_person_audit_person_id ON person_audit(person_id);
CREATE INDEX IF NOT EXISTS idx_person_audit_timestamp ON person_audit(audit_timestamp);
CREATE INDEX IF NOT EXISTS idx_person_audit_type ON person_audit(audit_type_id);
CREATE INDEX IF NOT EXISTS idx_person_audit_person_id_timestamp ON person_audit(person_id, audit_timestamp DESC);

-- person_account_ownership_audit: Audit trail for person_account_ownership table
CREATE TABLE person_account_ownership_audit (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    audit_timestamp INTEGER NOT NULL,
    audit_type_id INTEGER NOT NULL,
    person_account_ownership_id INTEGER NOT NULL,
    revision_id INTEGER NOT NULL,
    person_id INTEGER NOT NULL,
    account_id INTEGER NOT NULL,
    FOREIGN KEY (audit_type_id) REFERENCES audit_type(id)
);

CREATE INDEX IF NOT EXISTS idx_person_account_ownership_audit_person_account_ownership_id ON person_account_ownership_audit(person_account_ownership_id);
CREATE INDEX IF NOT EXISTS idx_person_account_ownership_audit_timestamp ON person_account_ownership_audit(audit_timestamp);
CREATE INDEX IF NOT EXISTS idx_person_account_ownership_audit_type ON person_account_ownership_audit(audit_type_id);
CREATE INDEX IF NOT EXISTS idx_person_account_ownership_audit_person_account_ownership_id_timestamp ON person_account_ownership_audit(person_account_ownership_id, audit_timestamp DESC);

-- api_import_strategy_audit: Audit trail for api_import_strategy table
CREATE TABLE api_import_strategy_audit (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    audit_timestamp INTEGER NOT NULL,
    audit_type_id INTEGER NOT NULL,
    api_import_strategy_id TEXT NOT NULL,
    revision_id INTEGER NOT NULL,
    name TEXT NOT NULL,
    config_json TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL,
    FOREIGN KEY (audit_type_id) REFERENCES audit_type(id)
);

CREATE INDEX IF NOT EXISTS idx_api_import_strategy_audit_strategy_id ON api_import_strategy_audit(api_import_strategy_id);
CREATE INDEX IF NOT EXISTS idx_api_import_strategy_audit_timestamp ON api_import_strategy_audit(audit_timestamp);
CREATE INDEX IF NOT EXISTS idx_api_import_strategy_audit_type ON api_import_strategy_audit(audit_type_id);
CREATE INDEX IF NOT EXISTS idx_api_import_strategy_audit_strategy_id_timestamp ON api_import_strategy_audit(api_import_strategy_id, audit_timestamp DESC);

-- csv_import_strategy_audit: Audit trail for csv_import_strategy table
CREATE TABLE csv_import_strategy_audit (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    audit_timestamp INTEGER NOT NULL,
    audit_type_id INTEGER NOT NULL,
    csv_import_strategy_id TEXT NOT NULL,
    revision_id INTEGER NOT NULL,
    name TEXT NOT NULL,
    identification_columns_json TEXT NOT NULL,
    field_mappings_json TEXT NOT NULL,
    attribute_mappings_json TEXT NOT NULL,
    row_rules_json TEXT NOT NULL,
    companion_rules_json TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL,
    FOREIGN KEY (audit_type_id) REFERENCES audit_type(id)
);

CREATE INDEX IF NOT EXISTS idx_csv_import_strategy_audit_strategy_id ON csv_import_strategy_audit(csv_import_strategy_id);
CREATE INDEX IF NOT EXISTS idx_csv_import_strategy_audit_timestamp ON csv_import_strategy_audit(audit_timestamp);
CREATE INDEX IF NOT EXISTS idx_csv_import_strategy_audit_type ON csv_import_strategy_audit(audit_type_id);
CREATE INDEX IF NOT EXISTS idx_csv_import_strategy_audit_strategy_id_timestamp ON csv_import_strategy_audit(csv_import_strategy_id, audit_timestamp DESC);

-- import_directory_audit: Audit trail for import_directory table (full row snapshot per revision,
-- written by custom triggers because import_directory is excluded from the generic audit mechanism).
CREATE TABLE import_directory_audit (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    audit_timestamp INTEGER NOT NULL,
    audit_type_id INTEGER NOT NULL,
    import_directory_id TEXT NOT NULL,
    revision_id INTEGER NOT NULL,
    name TEXT NOT NULL,
    provider_type_id INTEGER NOT NULL,
    folder_ref TEXT NOT NULL,
    folder_display_path TEXT,
    provider_config TEXT,
    device_id INTEGER,
    top_level INTEGER NOT NULL,
    parent_id TEXT,
    excluded INTEGER NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL,
    FOREIGN KEY (audit_type_id) REFERENCES audit_type(id)
);

CREATE INDEX IF NOT EXISTS idx_import_directory_audit_directory_id ON import_directory_audit(import_directory_id);
CREATE INDEX IF NOT EXISTS idx_import_directory_audit_timestamp ON import_directory_audit(audit_timestamp);
CREATE INDEX IF NOT EXISTS idx_import_directory_audit_type ON import_directory_audit(audit_type_id);
CREATE INDEX IF NOT EXISTS idx_import_directory_audit_directory_id_timestamp ON import_directory_audit(import_directory_id, audit_timestamp DESC);

-- pass_through_account_audit: Audit trail for pass_through_account table (full row snapshot per change,
-- written by custom triggers because pass_through_account is excluded from the generic audit mechanism).
-- User-editable config (like csv_import_strategy / import_directory) must be audited so create/update/delete
-- register in dataChangeToken() and therefore sync. Unlike those, pass_through_account carries no
-- provenance/source (it is user-configured lookup data, not imported), so there is no companion _source
-- table and the audit rows are only ever counted (dataChangeToken() sums COUNT(*) across *_audit tables);
-- the id PK is therefore never selected. See TriggerFlagTables.sq for the same noinspection rationale.
-- noinspection UnusedColumn
CREATE TABLE pass_through_account_audit (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    audit_timestamp INTEGER NOT NULL,
    audit_type_id INTEGER NOT NULL,
    pass_through_account_id INTEGER NOT NULL,
    name TEXT NOT NULL,
    conduit_account_name TEXT NOT NULL,
    relationship_type_id INTEGER NOT NULL,
    rules_json TEXT NOT NULL,
    FOREIGN KEY (audit_type_id) REFERENCES audit_type(id)
);

CREATE INDEX IF NOT EXISTS idx_pass_through_account_audit_account_id ON pass_through_account_audit(pass_through_account_id);
CREATE INDEX IF NOT EXISTS idx_pass_through_account_audit_timestamp ON pass_through_account_audit(audit_timestamp);
CREATE INDEX IF NOT EXISTS idx_pass_through_account_audit_type ON pass_through_account_audit(audit_type_id);
CREATE INDEX IF NOT EXISTS idx_pass_through_account_audit_account_id_timestamp ON pass_through_account_audit(pass_through_account_id, audit_timestamp DESC);
