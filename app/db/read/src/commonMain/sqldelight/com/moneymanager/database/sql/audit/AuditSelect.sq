-- Get audit history for a category
-- entity_type_id = 5 for CATEGORY
selectAuditHistoryForCategory:
SELECT
    category_audit.id,
    category_audit.audit_timestamp,
    audit_type.name AS audit_type,
    category_audit.category_id,
    category_audit.revision_id,
    category_audit.name,
    category_audit.parent_id,
    category_audit.parent_name,
    -- Source information
    entity_source.id AS source_id,
    entity_source.device_id AS source_device_id,
    source_type.id AS source_type_id,
    source_type.name AS source_type_name,
    device_view.platform_name AS source_platform_name,
    device_view.os_name AS source_os_name,
    device_view.machine_name AS source_machine_name,
    device_view.device_make AS source_device_make,
    device_view.device_model AS source_device_model,
    entity_source.created_at AS source_created_at,
    api_entity_source.api_session_id AS source_api_session_id,
    api_entity_source.api_request_id AS source_api_request_id,
    api_entity_source.json_path AS source_api_json_path,
    csv_entity_source.csv_import_id AS source_csv_import_id,
    csv_entity_source.csv_row_index AS source_csv_row_index,
    csv_import_metadata.original_file_name AS source_csv_file_name,
    qif_entity_source.qif_import_id AS source_qif_import_id,
    qif_entity_source.qif_record_index AS source_qif_record_index,
    qif_import_metadata.original_file_name AS source_qif_file_name
FROM category_audit
JOIN audit_type ON category_audit.audit_type_id = audit_type.id
LEFT JOIN entity_source ON category_audit.category_id = entity_source.entity_id
    AND category_audit.revision_id = entity_source.revision_id
    AND entity_source.entity_type_id = 5
LEFT JOIN source_type ON entity_source.source_type_id = source_type.id
LEFT JOIN device_view ON entity_source.device_id = device_view.id
LEFT JOIN api_entity_source ON entity_source.id = api_entity_source.id
LEFT JOIN csv_entity_source ON entity_source.id = csv_entity_source.id
LEFT JOIN csv_import_metadata ON csv_entity_source.csv_import_id = csv_import_metadata.id
LEFT JOIN qif_entity_source ON entity_source.id = qif_entity_source.id
LEFT JOIN qif_import_metadata ON qif_entity_source.qif_import_id = qif_import_metadata.id
WHERE category_audit.category_id = ?
ORDER BY category_audit.audit_timestamp DESC, category_audit.id DESC;

-- Get audit history for an api import strategy
selectAuditHistoryForApiImportStrategy:
SELECT
    api_import_strategy_audit.id,
    api_import_strategy_audit.audit_timestamp,
    audit_type.name AS audit_type,
    api_import_strategy_audit.api_import_strategy_id,
    api_import_strategy_audit.revision_id,
    api_import_strategy_audit.name,
    api_import_strategy_audit.config_json,
    api_import_strategy_audit.created_at,
    api_import_strategy_audit.updated_at,
    -- Source information
    api_import_strategy_source.id AS source_id,
    api_import_strategy_source.device_id AS source_device_id,
    source_type.id AS source_type_id,
    source_type.name AS source_type_name,
    device_view.platform_name AS source_platform_name,
    device_view.os_name AS source_os_name,
    device_view.machine_name AS source_machine_name,
    device_view.device_make AS source_device_make,
    device_view.device_model AS source_device_model,
    api_import_strategy_source.created_at AS source_created_at
FROM api_import_strategy_audit
JOIN audit_type ON api_import_strategy_audit.audit_type_id = audit_type.id
LEFT JOIN api_import_strategy_source ON api_import_strategy_audit.api_import_strategy_id = api_import_strategy_source.strategy_id
    AND api_import_strategy_audit.revision_id = api_import_strategy_source.revision_id
LEFT JOIN source_type ON api_import_strategy_source.source_type_id = source_type.id
LEFT JOIN device_view ON api_import_strategy_source.device_id = device_view.id
WHERE api_import_strategy_audit.api_import_strategy_id = ?
ORDER BY api_import_strategy_audit.audit_timestamp DESC, api_import_strategy_audit.id DESC;

-- Get audit history for a csv import strategy
selectAuditHistoryForCsvImportStrategy:
SELECT
    csv_import_strategy_audit.id,
    csv_import_strategy_audit.audit_timestamp,
    audit_type.name AS audit_type,
    csv_import_strategy_audit.csv_import_strategy_id,
    csv_import_strategy_audit.revision_id,
    csv_import_strategy_audit.name,
    csv_import_strategy_audit.identification_columns_json,
    csv_import_strategy_audit.field_mappings_json,
    csv_import_strategy_audit.attribute_mappings_json,
    csv_import_strategy_audit.row_rules_json,
    csv_import_strategy_audit.companion_rules_json,
    csv_import_strategy_audit.created_at,
    csv_import_strategy_audit.updated_at,
    -- Source information
    csv_import_strategy_source.id AS source_id,
    csv_import_strategy_source.device_id AS source_device_id,
    source_type.id AS source_type_id,
    source_type.name AS source_type_name,
    device_view.platform_name AS source_platform_name,
    device_view.os_name AS source_os_name,
    device_view.machine_name AS source_machine_name,
    device_view.device_make AS source_device_make,
    device_view.device_model AS source_device_model,
    csv_import_strategy_source.created_at AS source_created_at
FROM csv_import_strategy_audit
JOIN audit_type ON csv_import_strategy_audit.audit_type_id = audit_type.id
LEFT JOIN csv_import_strategy_source ON csv_import_strategy_audit.csv_import_strategy_id = csv_import_strategy_source.strategy_id
    AND csv_import_strategy_audit.revision_id = csv_import_strategy_source.revision_id
LEFT JOIN source_type ON csv_import_strategy_source.source_type_id = source_type.id
LEFT JOIN device_view ON csv_import_strategy_source.device_id = device_view.id
WHERE csv_import_strategy_audit.csv_import_strategy_id = ?
ORDER BY csv_import_strategy_audit.audit_timestamp DESC, csv_import_strategy_audit.id DESC;

-- Get audit history for an import directory
selectAuditHistoryForImportDirectory:
SELECT
    import_directory_audit.id,
    import_directory_audit.audit_timestamp,
    audit_type.name AS audit_type,
    import_directory_audit.import_directory_id,
    import_directory_audit.revision_id,
    import_directory_audit.name,
    import_directory_provider.name AS provider_type,
    import_directory_audit.folder_ref,
    import_directory_audit.folder_display_path,
    import_directory_audit.provider_config,
    import_directory_audit.device_id,
    import_directory_audit.top_level,
    import_directory_audit.parent_id,
    import_directory_audit.excluded,
    import_directory_audit.account_id,
    import_directory_audit.created_at,
    import_directory_audit.updated_at,
    -- Source information
    import_directory_source.id AS source_id,
    import_directory_source.device_id AS source_device_id,
    source_type.id AS source_type_id,
    source_type.name AS source_type_name,
    device_view.platform_name AS source_platform_name,
    device_view.os_name AS source_os_name,
    device_view.machine_name AS source_machine_name,
    device_view.device_make AS source_device_make,
    device_view.device_model AS source_device_model,
    import_directory_source.created_at AS source_created_at
FROM import_directory_audit
JOIN audit_type ON import_directory_audit.audit_type_id = audit_type.id
JOIN import_directory_provider ON import_directory_audit.provider_type_id = import_directory_provider.id
LEFT JOIN import_directory_source ON import_directory_audit.import_directory_id = import_directory_source.directory_id
    AND import_directory_audit.revision_id = import_directory_source.revision_id
LEFT JOIN source_type ON import_directory_source.source_type_id = source_type.id
LEFT JOIN device_view ON import_directory_source.device_id = device_view.id
WHERE import_directory_audit.import_directory_id = ?
ORDER BY import_directory_audit.audit_timestamp DESC, import_directory_audit.id DESC;

selectAuditHistoryForCrypto:
SELECT
    crypto_audit.id,
    crypto_audit.audit_timestamp,
    audit_type.name AS audit_type,
    crypto_audit.crypto_id,
    crypto_audit.revision_id,
    crypto_audit.code,
    crypto_audit.name,
    crypto_audit.scale_factor,
    -- Source information
    entity_source.id AS source_id,
    entity_source.device_id AS source_device_id,
    source_type.id AS source_type_id,
    source_type.name AS source_type_name,
    device_view.platform_name AS source_platform_name,
    device_view.os_name AS source_os_name,
    device_view.machine_name AS source_machine_name,
    device_view.device_make AS source_device_make,
    device_view.device_model AS source_device_model,
    entity_source.created_at AS source_created_at,
    api_entity_source.api_session_id AS source_api_session_id,
    api_entity_source.api_request_id AS source_api_request_id,
    api_entity_source.json_path AS source_api_json_path,
    csv_entity_source.csv_import_id AS source_csv_import_id,
    csv_entity_source.csv_row_index AS source_csv_row_index,
    csv_import_metadata.original_file_name AS source_csv_file_name,
    qif_entity_source.qif_import_id AS source_qif_import_id,
    qif_entity_source.qif_record_index AS source_qif_record_index,
    qif_import_metadata.original_file_name AS source_qif_file_name
FROM crypto_audit
JOIN audit_type ON crypto_audit.audit_type_id = audit_type.id
LEFT JOIN entity_source ON crypto_audit.crypto_id = entity_source.entity_id
    AND crypto_audit.revision_id = entity_source.revision_id
    AND entity_source.entity_type_id = 10
LEFT JOIN source_type ON entity_source.source_type_id = source_type.id
LEFT JOIN device_view ON entity_source.device_id = device_view.id
LEFT JOIN api_entity_source ON entity_source.id = api_entity_source.id
LEFT JOIN csv_entity_source ON entity_source.id = csv_entity_source.id
LEFT JOIN csv_import_metadata ON csv_entity_source.csv_import_id = csv_import_metadata.id
LEFT JOIN qif_entity_source ON entity_source.id = qif_entity_source.id
LEFT JOIN qif_import_metadata ON qif_entity_source.qif_import_id = qif_import_metadata.id
WHERE crypto_audit.crypto_id = ?
ORDER BY crypto_audit.audit_timestamp DESC, crypto_audit.id DESC;

selectAuditHistoryForTrade:
SELECT
    trade_audit.id,
    trade_audit.audit_timestamp,
    audit_type.name AS audit_type,
    trade_audit.trade_id,
    trade_audit.revision_id,
    trade_audit.timestamp,
    trade_audit.description,
    trade_audit.from_account_id,
    trade_audit.from_amount,
    trade_audit.to_account_id,
    trade_audit.to_amount,
    from_asset.id AS from_asset_id,
    from_asset.code AS from_asset_code,
    from_asset.name AS from_asset_name,
    from_asset.scale_factor AS from_asset_scale_factor,
    from_asset.kind AS from_asset_kind,
    to_asset.id AS to_asset_id,
    to_asset.code AS to_asset_code,
    to_asset.name AS to_asset_name,
    to_asset.scale_factor AS to_asset_scale_factor,
    to_asset.kind AS to_asset_kind,
    -- Source information
    entity_source.id AS source_id,
    entity_source.device_id AS source_device_id,
    source_type.id AS source_type_id,
    source_type.name AS source_type_name,
    device_view.platform_name AS source_platform_name,
    device_view.os_name AS source_os_name,
    device_view.machine_name AS source_machine_name,
    device_view.device_make AS source_device_make,
    device_view.device_model AS source_device_model,
    entity_source.created_at AS source_created_at,
    api_entity_source.api_session_id AS source_api_session_id,
    api_entity_source.api_request_id AS source_api_request_id,
    api_entity_source.json_path AS source_api_json_path,
    csv_entity_source.csv_import_id AS source_csv_import_id,
    csv_entity_source.csv_row_index AS source_csv_row_index,
    csv_import_metadata.original_file_name AS source_csv_file_name,
    qif_entity_source.qif_import_id AS source_qif_import_id,
    qif_entity_source.qif_record_index AS source_qif_record_index,
    qif_import_metadata.original_file_name AS source_qif_file_name
FROM trade_audit
JOIN audit_type ON trade_audit.audit_type_id = audit_type.id
JOIN asset_details from_asset ON trade_audit.from_asset_id = from_asset.id
JOIN asset_details to_asset ON trade_audit.to_asset_id = to_asset.id
LEFT JOIN entity_source ON trade_audit.trade_id = entity_source.entity_id
    AND trade_audit.revision_id = entity_source.revision_id
    AND entity_source.entity_type_id = 11
LEFT JOIN source_type ON entity_source.source_type_id = source_type.id
LEFT JOIN device_view ON entity_source.device_id = device_view.id
LEFT JOIN api_entity_source ON entity_source.id = api_entity_source.id
LEFT JOIN csv_entity_source ON entity_source.id = csv_entity_source.id
LEFT JOIN csv_import_metadata ON csv_entity_source.csv_import_id = csv_import_metadata.id
LEFT JOIN qif_entity_source ON entity_source.id = qif_entity_source.id
LEFT JOIN qif_import_metadata ON qif_entity_source.qif_import_id = qif_import_metadata.id
WHERE trade_audit.trade_id = ?
ORDER BY trade_audit.audit_timestamp DESC, trade_audit.id DESC;

selectAuditHistoryForExchangeOrder:
SELECT
    exchange_order_audit.id,
    exchange_order_audit.audit_timestamp,
    audit_type.name AS audit_type,
    exchange_order_audit.exchange_order_id,
    exchange_order_audit.revision_id,
    exchange_order_audit.account_id,
    exchange_order_audit.order_ref,
    exchange_order_audit.client_oid,
    exchange_order_audit.side,
    exchange_order_audit.order_type,
    exchange_order_audit.time_in_force,
    exchange_order_audit.status,
    exchange_order_audit.limit_price,
    exchange_order_audit.quantity,
    exchange_order_audit.avg_price,
    exchange_order_audit.created_at,
    exchange_order_audit.updated_at,
    -- Source information
    entity_source.id AS source_id,
    entity_source.device_id AS source_device_id,
    source_type.id AS source_type_id,
    source_type.name AS source_type_name,
    device_view.platform_name AS source_platform_name,
    device_view.os_name AS source_os_name,
    device_view.machine_name AS source_machine_name,
    device_view.device_make AS source_device_make,
    device_view.device_model AS source_device_model,
    entity_source.created_at AS source_created_at,
    api_entity_source.api_session_id AS source_api_session_id,
    api_entity_source.api_request_id AS source_api_request_id,
    api_entity_source.json_path AS source_api_json_path,
    csv_entity_source.csv_import_id AS source_csv_import_id,
    csv_entity_source.csv_row_index AS source_csv_row_index,
    csv_import_metadata.original_file_name AS source_csv_file_name,
    qif_entity_source.qif_import_id AS source_qif_import_id,
    qif_entity_source.qif_record_index AS source_qif_record_index,
    qif_import_metadata.original_file_name AS source_qif_file_name
FROM exchange_order_audit
JOIN audit_type ON exchange_order_audit.audit_type_id = audit_type.id
LEFT JOIN entity_source ON exchange_order_audit.exchange_order_id = entity_source.entity_id
    AND exchange_order_audit.revision_id = entity_source.revision_id
    AND entity_source.entity_type_id = 12
LEFT JOIN source_type ON entity_source.source_type_id = source_type.id
LEFT JOIN device_view ON entity_source.device_id = device_view.id
LEFT JOIN api_entity_source ON entity_source.id = api_entity_source.id
LEFT JOIN csv_entity_source ON entity_source.id = csv_entity_source.id
LEFT JOIN csv_import_metadata ON csv_entity_source.csv_import_id = csv_import_metadata.id
LEFT JOIN qif_entity_source ON entity_source.id = qif_entity_source.id
LEFT JOIN qif_import_metadata ON qif_entity_source.qif_import_id = qif_import_metadata.id
WHERE exchange_order_audit.exchange_order_id = ?
ORDER BY exchange_order_audit.audit_timestamp DESC, exchange_order_audit.id DESC;
